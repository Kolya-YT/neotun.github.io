  "help": {
    "steps": [
      { "n": 1, "title": "Войдите в личный кабинет NeoTUN", "text": "Авторизуйтесь через Telegram или Email в приложении или на сайте." },
      { "n": 2, "title": "Выберите тариф", "text": "Начните с бесплатного или выберите платный тариф в кабинете." },
      { "n": 3, "title": "Выберите совместимое приложение", "text": "Скачайте официальную сборку для своей платформы из GitHub Releases." },
      { "n": 4, "title": "Добавьте подписку", "text": "Импортируйте ссылку подписки из кабинета в приложение автоматически или вручную." },
      { "n": 5, "title": "Подключитесь", "text": "Выберите сервер и нажмите «Подключить»." }
    ],
    "faq": [
      { "q": "Какое приложение выбрать?", "a": "Для большинства подойдёт INCY или Hiddify — они кроссплатформенные и поддерживают все нужные протоколы. На Android удобен v2rayNG или Sing-box." },
      { "q": "Откуда скачиваются приложения?", "a": "Все приложения скачиваются напрямую из официальных GitHub Releases их разработчиков. NeoTUN лишь подбирает нужный файл — вы получаете оригинальную сборку без изменений." },
      { "q": "Почему скачивание идёт через GitHub?", "a": "Потому что эти приложения разрабатываются независимыми авторами и распространяются через GitHub Releases. Так вы всегда получаете последнюю официальную версию." },
      { "q": "Что делать, если для платформы нет сборки?", "a": "Откройте страницу релизов на GitHub вручную по ссылке из уведомления — возможно, сборка появится в следующем релизе." },
      { "q": "Как добавить подписку NeoTUN?", "a": "После входа через Telegram или Email откройте личный кабинет, скопируйте ссылку подписки и импортируйте её в выбранное приложение." }
    ]
